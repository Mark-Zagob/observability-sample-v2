      "id": 10,
      "title": "Inventory — OPS",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(inventory_updates_total[5m]))",
