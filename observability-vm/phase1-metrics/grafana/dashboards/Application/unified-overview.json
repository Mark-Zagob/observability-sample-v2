    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 4,
      "title": "Payment Error Rate",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "(sum(rate(payments_total{status=\"failed\"}[5m])) or vector(0)) / sum(rate(payments_total[5m]))",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📈 Traffic & Latency (Metrics — Prometheus)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "min": 0,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "title": "Request Rate — All Services",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(api_gateway_requests_total[5m]))",
          "legendFormat": "API Gateway"
        },
        {
          "expr": "sum(rate(orders_created_total[5m]))",
          "legendFormat": "Order Service"
        },
        {
          "expr": "sum(rate(payments_total[5m]))",
          "legendFormat": "Payment Service"
        },
        {
          "expr": "sum(rate(notifications_sent_total[5m]))",
          "legendFormat": "Notification Worker"
        },
        {
          "expr": "sum(rate(inventory_updates_total[5m]))",
          "legendFormat": "Inventory Worker"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "min": 0,
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "title": "P95 Latency — All Services",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_gateway_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "API Gateway"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(order_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Order Service"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(payment_gateway_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Payment Gateway"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(notification_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Notification Worker"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inventory_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Inventory Worker"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "📋 Live Logs (Logs — Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki-datasource" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "id": 7,
      "title": "Application Logs (JSON — click TraceID to jump to trace)",
      "description": "Structured JSON logs from all 3 services. Click the TraceID link to correlate with Tempo traces.",
      "type": "logs",
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-datasource" },
          "expr": "{container_name=~\"api-gateway|order-service|payment-service|notification-worker|inventory-worker\"} | json",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "🔍 Recent Traces (Traces — Tempo)",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo-datasource" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "id": 8,
      "title": "Recent Traces (click to explore full trace)",
      "description": "Recent distributed traces. Click any trace to view the full waterfall diagram.",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo-datasource" },
          "queryType": "nativeSearch",
          "limit": 20,
          "refId": "A"
        }
      ]
    }
