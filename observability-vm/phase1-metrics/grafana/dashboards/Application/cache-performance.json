{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Cache Hit Ratio (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cache_operations_total{result=\"hit\",job=\"app-metrics\"}[5m])) / (sum(rate(cache_operations_total{result=\"hit\",job=\"app-metrics\"}[5m])) + sum(rate(cache_operations_total{result=\"miss\",job=\"app-metrics\"}[5m])))",
          "legendFormat": "Hit Ratio"
        }
      ]
    },
    {
      "title": "Cache Operations per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cache_operations_total{job=\"app-metrics\"}[5m])) by (operation, result)",
          "legendFormat": "{{ operation }} — {{ result }}"
        }
      ]
    },
    {
      "title": "Cache Operation Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(cache_operation_duration_seconds_bucket{job=\"app-metrics\"}[5m])) by (le, operation))",
          "legendFormat": "p95 — {{ operation }}"
        }
      ]
    },
    {
      "title": "Cache Miss → DB Fallback Impact",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{operation=\"select\",job=\"app-metrics\"}[5m])) by (le))",
          "legendFormat": "DB SELECT p95 (on cache miss)"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cache_operation_duration_seconds_bucket{operation=\"get\",job=\"app-metrics\"}[5m])) by (le))",
          "legendFormat": "Cache GET p95 (on cache hit)"
        }
      ]
    },
    {
      "title": "Cache Hit vs Miss Rate",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cache_operations_total{operation=\"get\",job=\"app-metrics\"}[5m])) by (result)",
          "legendFormat": "{{ result }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["application", "cache", "redis"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Cache Performance",
  "uid": "cache-performance"
}
