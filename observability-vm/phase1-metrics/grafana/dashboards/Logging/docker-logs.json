    "schemaVersion": 39,
    "tags": ["loki", "logging", "phase2"],
    "templating": {
        "list": [
            {
                "allValue": ".*",
                "current": { "selected": true, "text": "All", "value": "$__all" },
                "datasource": { "type": "loki", "uid": "loki-datasource" },
                "definition": "label_values({source=\"docker\"}, vm)",
                "includeAll": true,
                "label": "VM",
                "multi": true,
                "name": "vm",
                "query": "label_values({source=\"docker\"}, vm)",
                "refresh": 2,
                "type": "query"
            }
        ]
    },
    "time": { "from": "now-1h", "to": "now" },
    "timezone": "browser",
    "title": "Docker Logs Overview",
    "uid": "docker-logs-overview",
    "version": 2
}