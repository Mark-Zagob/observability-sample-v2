#--------------------------------------------------------------
# Database Module — Lambda-Based Secret Rotation (Level 2)
#--------------------------------------------------------------
# ⚠️ FILE NÀY LÀ TÀI LIỆU THAM KHẢO — KHÔNG ACTIVE
# Toàn bộ resources đã được comment out.
#
# Module hiện tại dùng Level 3 (RDS Managed Rotation).
# File này minh họa Level 2 nếu bạn cần:
#   - Custom rotation logic
#   - Multi-database rotation (1 Lambda → nhiều RDS)
#   - Cross-account rotation
#   - Non-RDS databases (DocumentDB, Redshift)
#--------------------------------------------------------------

#--------------------------------------------------------------
# OVERVIEW: 4-Step Rotation Protocol
#--------------------------------------------------------------
# AWS Secrets Manager rotation dùng 4-step protocol.
# Lambda function được gọi 4 LẦN liên tiếp, mỗi lần với 1 "step":
#
# Step 1: createSecret
#   → Lambda tạo password MỚI
#   → Lưu vào secret version AWSPENDING
#   → Password cũ (AWSCURRENT) vẫn hoạt động
#
# Step 2: setSecret
#   → Lambda kết nối vào PostgreSQL (dùng password CŨ)
#   → Chạy: ALTER USER dbadmin WITH PASSWORD 'new_password'
#   → Bây giờ CẢ 2 password đều hoạt động (dual-secret pattern)
#
# Step 3: testSecret
#   → Lambda kết nối vào PostgreSQL bằng password MỚI
#   → Nếu thành công → tiếp tục Step 4
#   → Nếu thất bại → rollback, giữ password cũ
#
# Step 4: finishSecret
#   → Lambda đổi label:
#       AWSPENDING  → AWSCURRENT (password mới)
#       AWSCURRENT  → AWSPREVIOUS (password cũ)
#   → App đọc AWSCURRENT → tự động nhận password mới
#
# Timeline:
# t=0  [CURRENT: old_pw]  [PENDING: ---]
# t=1  [CURRENT: old_pw]  [PENDING: new_pw]     ← createSecret
# t=2  DB accepts both old_pw AND new_pw         ← setSecret
# t=3  Lambda tests new_pw → success             ← testSecret
# t=4  [CURRENT: new_pw]  [PREVIOUS: old_pw]     ← finishSecret
#--------------------------------------------------------------

#--------------------------------------------------------------
# ARCHITECTURE DIAGRAM
#--------------------------------------------------------------
#
#  Secrets Manager                    Lambda                     RDS PostgreSQL
#  ┌────────────┐    Trigger    ┌──────────────┐    SQL       ┌──────────────┐
#  │            │──────────────→│              │─────────────→│              │
#  │  Secret    │   (4 steps)  │  Rotation    │  ALTER USER  │  PostgreSQL  │
#  │            │←──────────────│  Function    │←─────────────│              │
#  │ AWSCURRENT │    Update    │              │   Verify     │              │
#  │ AWSPENDING │              │  (VPC内)     │              │              │
#  └────────────┘              └──────────────┘              └──────────────┘
#                                     │
#                              Runs INSIDE VPC
#                              (cần truy cập RDS)
#--------------------------------------------------------------

#--------------------------------------------------------------
# CÁC THÀNH PHẦN CẦN THIẾT
#--------------------------------------------------------------

# ============================================================
# 1. Lambda Function (dùng AWS template có sẵn cho PostgreSQL)
# ============================================================
# AWS cung cấp sẵn Lambda template cho RDS PostgreSQL.
# Không cần viết code Python từ đầu.
#
# resource "aws_serverlessapplicationrepository_cloudformation_stack" "rotation" {
#   name           = "${local.identifier}-secret-rotation"
#   application_id = "arn:aws:serverlessrepo:us-east-1:297356227824:applications/SecretsManagerRDSPostgreSQLRotationSingleUser"
#   #                                                                             ↑
#   #              AWS Official Template — Single User rotation for PostgreSQL
#   #
#   # Variant khác:
#   #   SecretsManagerRDSPostgreSQLRotationMultiUser  ← dùng 2 user luân phiên
#   #   SecretsManagerRDSMySQLRotationSingleUser      ← cho MySQL
#   #   SecretsManagerRDSMariaDBRotationSingleUser    ← cho MariaDB
#   #   SecretsManagerRDSSQLServerRotationSingleUser  ← cho SQL Server
#
#   parameters = {
#     # Secrets Manager VPC Endpoint — Lambda gọi Secrets Manager qua PrivateLink
#     # (không qua Internet, bắt buộc vì Lambda ở Private Subnet)
#     endpoint     = "https://secretsmanager.${data.aws_region.current.name}.amazonaws.com"
#     functionName = "${local.identifier}-secret-rotation"
#
#     # VPC config — Lambda PHẢI ở cùng VPC với RDS
#     vpcSubnetIds        = join(",", var.data_subnet_ids)
#     vpcSecurityGroupIds = var.data_security_group_id
#   }
#
#   # Capabilities: Lambda template cần tạo IAM role cho chính nó
#   capabilities = ["CAPABILITY_IAM"]
# }

# ============================================================
# 2. Secrets Manager Secret (manual — không phải RDS managed)
# ============================================================
# Với Level 2, bạn TỰ tạo secret (không dùng manage_master_user_password)
#
# resource "random_password" "db_master" {
#   length           = 24
#   special          = true
#   override_special = "!#$%&*()-_=+?,."
#
#   lifecycle {
#     ignore_changes = [length, special, override_special]
#   }
# }
#
# resource "aws_secretsmanager_secret" "db_master_password" {
#   name        = "${var.project_name}/${var.environment}/database/master-password"
#   description = "RDS PostgreSQL master password (Lambda-rotated)"
#
#   kms_key_id              = aws_kms_key.rds.arn
#   recovery_window_in_days = var.environment == "prod" ? 30 : 7
#
#   tags = merge(var.common_tags, {
#     Name      = "${var.project_name}-db-master-password"
#     Component = "database"
#   })
# }
#
# resource "aws_secretsmanager_secret_version" "db_master_password" {
#   secret_id = aws_secretsmanager_secret.db_master_password.id
#   secret_string = jsonencode({
#     username = var.db_username
#     password = random_password.db_master.result
#     engine   = "postgres"
#     host     = aws_db_instance.postgres.address
#     port     = aws_db_instance.postgres.port
#     dbname   = var.db_name
#   })
# }

# ============================================================
# 3. Rotation Configuration (kết nối Secret ↔ Lambda)
# ============================================================
# Đây là resource "keo dán" giữa Secret và Lambda:
#   - Lần đầu apply: trigger rotation ngay lập tức
#   - Sau đó: tự động rotate theo schedule
#
# resource "aws_secretsmanager_secret_rotation" "db_master" {
#   secret_id = aws_secretsmanager_secret.db_master_password.id
#
#   # ARN của Lambda function (tạo bởi SAR template ở trên)
#   rotation_lambda_arn = aws_serverlessapplicationrepository_cloudformation_stack.rotation.outputs["RotationLambdaARN"]
#
#   rotation_rules {
#     # Rotate mỗi 30 ngày
#     automatically_after_days = 30
#
#     # Schedule expression (alternative — dùng cron)
#     # schedule_expression = "cron(0 4 ? * SUN *)"  ← mỗi Chủ Nhật 4AM UTC
#   }
# }

# ============================================================
# 4. Lambda Permissions
# ============================================================
# Secrets Manager cần quyền INVOKE Lambda function
#
# resource "aws_lambda_permission" "secrets_manager" {
#   statement_id  = "AllowSecretsManagerInvoke"
#   action        = "lambda:InvokeFunction"
#   function_name = aws_serverlessapplicationrepository_cloudformation_stack.rotation.outputs["RotationLambdaARN"]
#   principal     = "secretsmanager.amazonaws.com"
# }

# ============================================================
# 5. VPC Endpoint cho Secrets Manager (QUAN TRỌNG!)
# ============================================================
# Lambda ở Private Subnet → KHÔNG có Internet access
# → Cần VPC Endpoint để gọi Secrets Manager API
#
# resource "aws_vpc_endpoint" "secretsmanager" {
#   vpc_id              = var.vpc_id
#   service_name        = "com.amazonaws.${data.aws_region.current.name}.secretsmanager"
#   vpc_endpoint_type   = "Interface"
#   subnet_ids          = var.data_subnet_ids
#   security_group_ids  = [var.data_security_group_id]
#   private_dns_enabled = true
# }

#--------------------------------------------------------------
# SO SÁNH: Single-User vs Multi-User rotation
#--------------------------------------------------------------
#
# Single-User (đang dùng ở ví dụ trên):
#   - 1 user: dbadmin
#   - Khi rotate: ALTER USER dbadmin WITH PASSWORD 'new_pw'
#   - Risk: trong vài ms giữa ALTER và AWSCURRENT update,
#           app có thể dùng password cũ → connection fail
#   - Mitigation: app cần retry logic
#
# Multi-User (production enterprise):
#   - 2 users: dbadmin_a, dbadmin_b
#   - Rotation luân phiên:
#       Lần 1: dùng dbadmin_a, tạo password mới cho dbadmin_b
#       Lần 2: dùng dbadmin_b, tạo password mới cho dbadmin_a
#   - Zero-downtime: luôn có 1 user đang hoạt động
#   - Phức tạp hơn: cần 2 secrets, 2 DB users
#
#--------------------------------------------------------------

#--------------------------------------------------------------
# KHI NÀO DÙNG LEVEL 2 (Lambda) thay vì LEVEL 3 (RDS Managed)?
#--------------------------------------------------------------
#
# Dùng Level 2 khi:
#   ✅ Database KHÔNG hỗ trợ managed rotation (DocumentDB, Redshift, Aurora Serverless v1)
#   ✅ Cần custom rotation logic (ví dụ: rotate + revoke old sessions)
#   ✅ Multi-user rotation (2 users luân phiên cho zero-downtime)
#   ✅ Cross-account: secret ở Account A, RDS ở Account B
#   ✅ Cần rotate NON-database secrets (API keys, certificates)
#
# Dùng Level 3 (RDS Managed) khi:
#   ✅ RDS PostgreSQL / MySQL / MariaDB / Oracle / SQL Server
#   ✅ Single master user
#   ✅ Không cần custom logic
#   ✅ Đơn giản nhất có thể
#
#--------------------------------------------------------------
