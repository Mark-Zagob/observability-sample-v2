{
    "annotations": {
        "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "links": [],
    "panels": [
        {
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
            "id": 100,
            "title": "📦 Container Overview",
            "type": "row"
        },
        {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "red", "value": 0 }
                        ]
                    }
                }
            },
            "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
            "id": 1,
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "value",
                "graphMode": "none"
            },
            "title": "Running Containers",
            "type": "stat",
            "targets": [
                {
                    "expr": "count(container_start_time_seconds{name!=\"\",vm=~\"$vm\"})",
                    "legendFormat": "{{ vm }}"
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
            "id": 101,
            "title": "⚡ CPU per Container",
            "type": "row"
        },
        {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "custom": { "fillOpacity": 10 }
                }
            },
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
            "id": 2,
            "title": "Container CPU Usage",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(container_cpu_usage_seconds_total{name!=\"\",vm=~\"$vm\"}[5m]) * 100",
                    "legendFormat": "{{ name }}"
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
            "id": 102,
            "title": "🧠 Memory per Container",
            "type": "row"
        },
        {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "min": 0,
                    "custom": { "fillOpacity": 10 }
                }
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
            "id": 3,
            "title": "Container Memory Usage",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "container_memory_usage_bytes{name!=\"\",vm=~\"$vm\"}",
                    "legendFormat": "{{ name }}"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "min": 0,
                    "custom": { "fillOpacity": 10 }
                }
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
            "id": 4,
            "title": "Container Memory Cache",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "container_memory_cache{name!=\"\",vm=~\"$vm\"}",
                    "legendFormat": "{{ name }}"
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
            "id": 103,
            "title": "🌐 Network per Container",
            "type": "row"
        },
        {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "fieldConfig": {
                "defaults": {
                    "unit": "Bps",
                    "min": 0,
                    "custom": { "fillOpacity": 10 }
                }
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
            "id": 5,
            "title": "Container Network RX (Receive)",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(container_network_receive_bytes_total{name!=\"\",vm=~\"$vm\"}[5m])",
                    "legendFormat": "{{ name }}"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "fieldConfig": {
                "defaults": {
                    "unit": "Bps",
                    "min": 0,
                    "custom": { "fillOpacity": 10 }
                }
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
            "id": 6,
            "title": "Container Network TX (Transmit)",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(container_network_transmit_bytes_total{name!=\"\",vm=~\"$vm\"}[5m])",
                    "legendFormat": "{{ name }}"
                }
            ]
        }
    ],
    "schemaVersion": 39,
    "tags": ["cadvisor", "docker", "containers", "phase1"],
    "templating": {
        "list": [
            {
                "allValue": ".*",
                "current": { "selected": true, "text": "All", "value": "$__all" },
                "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
                "definition": "label_values(container_cpu_usage_seconds_total, vm)",
                "includeAll": true,
                "label": "VM",
                "multi": true,
                "name": "vm",
                "query": "label_values(container_cpu_usage_seconds_total, vm)",
                "refresh": 2,
                "type": "query"
            }
        ]
    },
    "time": { "from": "now-1h", "to": "now" },
    "timepicker": {},
    "timezone": "browser",
    "title": "Docker Containers Monitoring",
    "uid": "docker-containers",
    "version": 2
}