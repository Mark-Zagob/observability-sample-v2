        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "id": 9,
      "title": "Inventory Updates (by Action)",
      "description": "Stock reservations and releases per second",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(inventory_updates_total[5m])) by (action)",
          "legendFormat": "{{ action }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
