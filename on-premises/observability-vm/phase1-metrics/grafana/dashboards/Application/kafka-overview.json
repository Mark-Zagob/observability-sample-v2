  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Kafka Cluster Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "title": "Messages In (per second)",
      "description": "Rate of messages produced to Kafka topics",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(kafka_topic_partition_current_offset[5m])) by (topic)",
          "legendFormat": "{{ topic }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "title": "Total Partitions per Topic",
      "description": "Number of partitions for each topic",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "expr": "count(kafka_topic_partition_current_offset) by (topic)",
          "legendFormat": "{{ topic }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "title": "Under-Replicated Partitions",
      "description": "Partitions that are under-replicated (should be 0)",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(kafka_topic_partition_under_replicated_partition) or vector(0)",
          "legendFormat": "Under-replicated"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "📈 Consumer Group Lag",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "title": "Consumer Group Lag",
      "description": "Total lag per consumer group — how many messages behind",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag) by (consumergroup)",
          "legendFormat": "{{ consumergroup }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "title": "Consumer Group Lag by Partition",
      "description": "Lag broken down by partition to spot hot partitions",
      "type": "timeseries",
      "targets": [
        {
          "expr": "kafka_consumergroup_lag{topic=\"order.events\"}",
          "legendFormat": "{{ consumergroup }} / p{{ partition }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "🔔 Notification Worker",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops",
          "min": 0,
          "custom": { "fillOpacity": 15, "lineWidth": 2, "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 6,
      "title": "Notifications Sent (by Type)",
      "description": "Notification throughput by type",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(notifications_sent_total[5m])) by (type)",
          "legendFormat": "{{ type }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "min": 0,
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 7,
      "title": "Notification Processing Duration (P95)",
      "description": "Time to process + send a notification",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(notification_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(notification_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops",
          "min": 0,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 8,
      "title": "Events Consumed (Notification Worker)",
      "description": "Kafka events consumed rate by event type",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(kafka_events_consumed_total{service_name=\"notification-worker\"}[5m])) by (event_type)",
          "legendFormat": "{{ event_type }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
