      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(inventory_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(inventory_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
