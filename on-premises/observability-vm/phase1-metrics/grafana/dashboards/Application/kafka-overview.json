      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(inventory_errors_total[5m])) or vector(0)",
          "legendFormat": "Error Rate"
        }
